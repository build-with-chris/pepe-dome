# Database
DATABASE_URL="postgresql://user:password@localhost:5432/pepe_dome?schema=public"
# Bei Supabase (Session-Mode Pooler): connection_limit setzen, sonst "MaxClientsInSessionMode" beim Newsletter-Versand.
# Beispiel: ...?schema=public&connection_limit=3

# Resend Email Service
RESEND_API_KEY="re_xxxxx"
RESEND_WEBHOOK_SECRET="whsec_xxxxx"
RESEND_FROM_EMAIL="PEPE Dome <info@pepeshows.de>"

# App Configuration (Basis-URL für Newsletter-Bestätigung, Abmeldelinks etc.)
# In Produktion auf die echte Domain setzen, z. B. https://pepe-dome.de
NEXT_PUBLIC_APP_URL="http://localhost:3004"
# Alternativ/fallback:
# NEXT_PUBLIC_BASE_URL="http://localhost:3004"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxx"
CLERK_SECRET_KEY="sk_test_xxxxx"
# Optional: set to "true" in development to browse the frontend without login (skips Clerk; admin routes unprotected)
# NEXT_PUBLIC_DISABLE_CLERK_IN_DEV="true"

# Cron Jobs
CRON_SECRET="your-secret-token-for-cron-jobs"

# File Storage (if using S3)
# S3_BUCKET="pepedome-newsletter-images"
# S3_REGION="eu-central-1"
# AWS_ACCESS_KEY_ID="xxxxx"
# AWS_SECRET_ACCESS_KEY="xxxxx"
